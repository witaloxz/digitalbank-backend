# ====================
# DATABASE
# ====================
POSTGRES_DB=digitalbank
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

DB_URL=jdbc:postgresql://postgres:5432/${POSTGRES_DB}
DB_USERNAME=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}
DB_POOL_SIZE=10

# ====================
# SPRING PROFILE
# ====================
SPRING_PROFILES_ACTIVE=prod

# ====================
# REDIS
# ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ====================
# JWT SECURITY
# ====================
JWT_SECRET=change_me_generate_with_openssl_rand_base64_64
JWT_EXPIRATION=86400000

# ====================
# ENCRYPTION
# ====================
ENCRYPTION_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# ====================
# ADMIN USER
# ====================
ADMIN_EMAIL=admin@bankdash.com
ADMIN_PASSWORD=change_me
ADMIN_NAME=System Administrator
ADMIN_CPF=12345678900
ADMIN_PHONE=+5511999999999

# ====================
# LOGGING
# ====================
LOG_LEVEL=INFO
SQL_LOG_LEVEL=WARN

# ====================
# FRONTEND
# ====================
VITE_API_URL=http://localhost:8080

# ====================
# PGADMIN
# ====================
PGADMIN_EMAIL=admin@bankdash.com
PGADMIN_PASSWORD=admin